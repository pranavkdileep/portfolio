---
const projects = [
	{
		name: 'Deployer',
		eyebrow: 'Open source · 50+ stars',
		description:
			'A self-hosted Docker control panel for deploying applications, services, and databases from one clean interface.',
		stack: ['Docker', 'Nixpacks', 'TypeScript'],
		href: 'https://github.com/pranavkdileep/Deployer',
		featured: true,
	},
	{
		name: 'JobInPark',
		eyebrow: 'AI job discovery',
		description:
			'A production job platform with skill matching, admin analytics, and coordinated alerts across email, Telegram, and WhatsApp.',
		stack: ['Next.js', 'MongoDB', 'Workflows'],
		href: 'https://github.com/pranavkdileep/jobinpark',
		featured: true,
	},
	{
		name: 'Study Note AI Agent',
		eyebrow: 'Document intelligence',
		description:
			'An AI agent that turns textbooks and images into structured notes using OCR, LLMs, and vectorless RAG.',
		stack: ['OpenAI', 'DeepSeek OCR', 'RAG'],
		href: 'https://www.ktucyber.com/agents',
		featured: true,
	},
	{
		name: 'DDoS Attack Detection',
		eyebrow: 'Security research',
		description:
			'A hybrid CNN, LSTM, and autoencoder model for identifying attacks in network-flow data.',
		stack: ['Python', 'Deep Learning', 'Go'],
		href: 'https://github.com/pranavkdileep/CICFlowMeter-Go',
	},
	{
		name: 'UPI Payment Gateway',
		eyebrow: 'Serverless payments',
		description:
			'A self-hosted gateway with automated payment verification, order matching, webhooks, and an operator dashboard.',
		stack: ['Cloudflare Workers', 'D1', 'Hono'],
		href: 'https://github.com/pranavkdileep/simple-upi-payment-gateway',
	},
	{
		name: 'Real-Time Bus Tracker',
		eyebrow: 'Mobile + IoT',
		description:
			'An end-to-end location system with passenger and conductor apps, a GPS device, and live WebSocket updates.',
		stack: ['Kotlin', 'ESP8266', 'WebSocket'],
	},
	{
		name: 'KTUcyber.com',
		eyebrow: 'Student community',
		description:
			'A collaborative study-material platform with authentication, email verification, bookmarks, and social features.',
		stack: ['Full stack', 'Authentication', 'CRUD'],
		href: 'https://github.com/pranavkdileep/ktucyber2.0',
	},
	{
		name: 'CampusTracker',
		eyebrow: 'Android application',
		description:
			'An Android client for a cloud student-management system, including resource downloads and live academic data.',
		stack: ['Android', 'Java', 'OkHttp'],
	},
];

const skills = [
	'TypeScript',
	'Go',
	'Python',
	'Java',
	'C++',
	'Docker',
	'Cloudflare',
	'Networking',
	'Cyber Security',
];

const ArrowIcon = `
	<svg viewBox="0 0 16 16" aria-hidden="true">
		<path d="M3.5 12.5 12 4m-6.5 0H12v6.5" />
	</svg>
`;
---

<div class="site-shell">
	<div class="scroll-progress" aria-hidden="true"></div>
	<div class="ambient ambient-one"></div>
	<div class="ambient ambient-two"></div>

	<header class="site-header">
		<a class="brand" href="#top" aria-label="Pranav K Dileep, home">
			<span class="brand-mark">P</span>
			<span>pranavkdileep</span>
		</a>

		<nav aria-label="Primary navigation">
			<a href="#work">Work</a>
			<a href="#about">About</a>
			<a href="#contact">Contact</a>
		</nav>

		<a class="header-status" href="mailto:pranavkdileepme@gmail.com">
			<span></span>
			Available for work
		</a>
	</header>

	<main id="top">
		<section class="hero" aria-labelledby="hero-title">
			<div class="hero-copy">
				<p class="kicker">Hello, I’m</p>
				<h1 id="hero-title">
					Pranav <span class="avatar" aria-hidden="true"><span>PKD</span></span> K Dileep.
					<span class="hero-muted">I build secure, scalable</span>
					<span class="accent">systems for the web.</span>
				</h1>
			</div>

			<div class="hero-action-row">
				<div class="hero-actions">
					<a class="button button-dark" href="#work">
						Explore my work
						<Fragment set:html={ArrowIcon} />
					</a>
					<a class="button button-light" href="/pranav-k-dileep-resume.pdf" download>
						Download resume
					</a>
				</div>
				<p>
					Computer Science & Cyber Security graduate focused on backend engineering, infrastructure,
					and useful software.
				</p>
			</div>
		</section>

		<section class="bento" aria-label="Portfolio highlights">
			<article class="card timeline-card">
				<p class="card-label">My journey</p>
				<div class="timeline">
					<div class="timeline-item">
						<span class="timeline-dot"></span>
						<div>
							<strong>Computer Science graduate</strong>
							<small>Cyber Security · 2022–2026</small>
						</div>
					</div>
					<div class="timeline-item">
						<span class="timeline-dot"></span>
						<div>
							<strong>Open-source builder</strong>
							<small>Web, Android & infrastructure</small>
						</div>
					</div>
					<div class="timeline-item">
						<span class="timeline-dot active"></span>
						<div>
							<strong>Ready for what’s next</strong>
							<small>Backend · Cloud · Security</small>
						</div>
					</div>
				</div>
			</article>

			<a
				class="card deployer-card"
				href="https://github.com/pranavkdileep/Deployer"
				target="_blank"
				rel="noreferrer"
			>
				<div class="card-top">
					<p class="card-label">Featured project</p>
					<span class="external" set:html={ArrowIcon}></span>
				</div>
				<div class="terminal" aria-hidden="true">
					<div class="terminal-bar"><span></span><span></span><span></span></div>
					<div class="terminal-body">
						<div class="terminal-sidebar">
							<b>Deploy</b>
							<i></i><i></i><i></i>
						</div>
						<div class="terminal-main">
							<span>production</span>
							<strong>Deployer</strong>
							<div class="deploy-line"><i></i><b></b></div>
							<div class="deploy-line"><i></i><b></b></div>
						</div>
					</div>
				</div>
				<div class="project-mini-title">
					<strong>Deployer</strong>
					<span>Self-hosted cloud control panel</span>
				</div>
			</a>

			<a
				class="card current-card"
				href="https://jobinpark.eu.cc"
				target="_blank"
				rel="noreferrer"
			>
				<div class="card-top">
					<p class="card-label">Currently building</p>
					<span class="external" set:html={ArrowIcon}></span>
				</div>
				<div class="job-visual" aria-hidden="true">
					<div class="job-logo">J</div>
					<div>
						<b>JobInPark</b>
						<span>Find work that fits.</span>
					</div>
					<i>AI</i>
				</div>
				<p>An intelligent job-discovery and multi-channel notification platform.</p>
			</a>

			<article class="card location-card">
				<div class="map-art" aria-hidden="true">
					<svg viewBox="0 0 400 210" preserveAspectRatio="none">
						<path d="M-20 50C60 20 80 95 155 62s108-40 146 2 73 35 120 5" />
						<path d="M28-20c26 60-3 102 45 137s69 27 86 113" />
						<path d="M215-10c-12 54 30 74 18 126s19 72 43 103" />
						<path d="M342-20c-24 53 17 91-13 127s-25 61-11 123" />
						<path d="M-20 151c79-27 122 22 193 0s148-14 248 20" />
					</svg>
					<span class="map-pin"><i></i></span>
				</div>
				<div class="location-name">
					<strong>THRISSUR</strong>
					<span>KERALA, INDIA</span>
				</div>
			</article>

			<article class="card stats-card">
				<p class="card-label">A few numbers</p>
				<div class="stats-grid">
					<div><strong>50+</strong><span>GitHub stars</span></div>
					<div><strong>10+</strong><span>Projects</span></div>
					<div><strong>8.09</strong><span>CGPA / 10</span></div>
				</div>
			</article>

			<article class="card focus-card">
				<p class="card-label">What I care about</p>
				<h2>Systems that are <span>secure by design</span> and pleasant to use.</h2>
				<div class="focus-tags">
					<span>Backend</span>
					<span>Infrastructure</span>
					<span>Security</span>
				</div>
			</article>
		</section>

		<section class="work-section section" id="work">
			<div class="section-heading">
				<div>
					<p class="kicker">Selected work</p>
					<h2>Things I’ve built.</h2>
				</div>
				<p>Projects spanning cloud infrastructure, applied AI, security research, mobile, and IoT.</p>
			</div>

			<div class="project-grid">
				{
					projects.map((project, index) => {
						const Tag = project.href ? 'a' : 'article';
						return (
							<Tag
								class:list={['project-card', { featured: project.featured }]}
								href={project.href}
								target={project.href ? '_blank' : undefined}
								rel={project.href ? 'noreferrer' : undefined}
							>
								<div class="project-number">{String(index + 1).padStart(2, '0')}</div>
								<div class="project-content">
									<p>{project.eyebrow}</p>
									<h3>{project.name}</h3>
									<span class="project-description">{project.description}</span>
									<div class="stack-list">
										{project.stack.map((item) => <span>{item}</span>)}
									</div>
								</div>
								{project.href && <span class="project-arrow" set:html={ArrowIcon} />}
							</Tag>
						);
					})
				}
			</div>
		</section>

		<section class="about-section section" id="about">
			<div class="about-copy">
				<p class="kicker">A little more about me</p>
				<h2>I like understanding how things work, then making them work better.</h2>
				<p>
					I’m a Computer Science and Engineering graduate specializing in Cyber Security. My work
					sits where backend systems, deployment infrastructure, networking, and product thinking
					meet. I learn fast, care about the details, and enjoy carrying ideas from a rough sketch to
					a running product.
				</p>
				<a class="text-link" href="mailto:pranavkdileepme@gmail.com">
					Let’s work together
					<Fragment set:html={ArrowIcon} />
				</a>
			</div>

			<div class="about-details">
				<div class="detail-block">
					<p class="card-label">Education</p>
					<strong>B.Tech, Computer Science & Engineering</strong>
					<span>Cyber Security · 2022–2026</span>
					<small>University College of Engineering, Thodupuzha</small>
				</div>
				<div class="detail-block">
					<p class="card-label">Tools & technologies</p>
					<div class="skill-cloud">
						{skills.map((skill) => <span>{skill}</span>)}
					</div>
				</div>
				<div class="detail-block languages">
					<p class="card-label">Languages</p>
					<strong>English</strong><span>Malayalam</span>
				</div>
			</div>
		</section>
	</main>

	<footer id="contact">
		<div class="footer-callout">
			<p class="kicker">Have a project or opportunity?</p>
			<h2>Let’s build something <span>worth using.</span></h2>
			<a class="button button-white" href="mailto:pranavkdileepme@gmail.com">
				Email me
				<Fragment set:html={ArrowIcon} />
			</a>
		</div>
		<div class="footer-bottom">
			<span>© 2026 Pranav K Dileep</span>
			<div>
				<a href="https://github.com/pranavkdileep" target="_blank" rel="noreferrer">GitHub</a>
				<a href="https://linkedin.com/in/pranavkdileep" target="_blank" rel="noreferrer"
					>LinkedIn</a
				>
				<a href="/pranav-k-dileep-resume.pdf" target="_blank">Resume</a>
			</div>
			<a href="#top">Back to top ↑</a>
		</div>
	</footer>
</div>

<style>
	:global(*) {
		box-sizing: border-box;
	}

	:global(html) {
		scroll-behavior: smooth;
		background: #efefed;
	}

	:global(body) {
		color: #121210;
		background:
			radial-gradient(circle at 18% 6%, rgba(255, 255, 255, 0.95), transparent 27rem),
			#efefed;
		font-family:
			Inter, ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		-webkit-font-smoothing: antialiased;
	}

	:global(a) {
		color: inherit;
	}

	:global(::selection) {
		color: #15120d;
		background: #ffb36c;
	}

	.site-shell {
		position: relative;
		min-height: 100vh;
		overflow: hidden;
	}

	.ambient {
		position: absolute;
		z-index: 0;
		border: 1px solid rgba(18, 18, 16, 0.035);
		border-radius: 999px;
		pointer-events: none;
	}

	.ambient-one {
		top: -32rem;
		right: -19rem;
		width: 75rem;
		height: 75rem;
		box-shadow:
			0 0 0 7rem rgba(255, 255, 255, 0.28),
			0 0 0 15rem rgba(255, 255, 255, 0.2);
	}

	.ambient-two {
		top: 39rem;
		left: -33rem;
		width: 58rem;
		height: 58rem;
		box-shadow: 0 0 0 6rem rgba(255, 255, 255, 0.22);
	}

	.site-header,
	main,
	footer {
		position: relative;
		z-index: 1;
		width: min(100% - 48px, 1040px);
		margin-inline: auto;
	}

	.site-header {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		padding: 32px 0 20px;
		font-size: 13px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 9px;
		width: fit-content;
		font-weight: 700;
		text-decoration: none;
		letter-spacing: -0.02em;
	}

	.brand-mark {
		display: grid;
		width: 28px;
		height: 28px;
		place-items: center;
		color: white;
		background: #151513;
		border-radius: 9px 9px 9px 4px;
		font-size: 12px;
	}

	nav {
		display: flex;
		gap: 7px;
		padding: 5px;
		background: rgba(255, 255, 255, 0.58);
		border: 1px solid rgba(255, 255, 255, 0.85);
		border-radius: 999px;
		box-shadow: 0 8px 30px rgba(30, 27, 20, 0.04);
		backdrop-filter: blur(14px);
	}

	nav a {
		padding: 7px 12px;
		border-radius: 999px;
		text-decoration: none;
		transition:
			color 180ms ease,
			background 180ms ease;
	}

	nav a:hover {
		background: white;
	}

	.header-status {
		display: inline-flex;
		align-items: center;
		justify-self: end;
		gap: 7px;
		text-decoration: none;
	}

	.header-status span {
		width: 7px;
		height: 7px;
		background: #2dd679;
		border: 2px solid #c8f5dc;
		border-radius: 50%;
		box-sizing: content-box;
	}

	.hero {
		padding: 80px 0 54px;
	}

	.kicker,
	.card-label {
		margin: 0;
		color: #73736d;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.hero .kicker {
		margin-bottom: 14px;
		color: #5f5e58;
	}

	h1 {
		max-width: 920px;
		margin: 0;
		font-size: clamp(48px, 7vw, 78px);
		font-weight: 690;
		line-height: 0.98;
		letter-spacing: -0.072em;
	}

	h1 > span:not(.avatar) {
		display: block;
	}

	.avatar {
		display: inline-grid;
		width: 0.85em;
		height: 0.85em;
		margin: 0 0.04em;
		place-items: center;
		overflow: hidden;
		color: #f2e8d7;
		background:
			radial-gradient(circle at 68% 28%, #f09b54 0 8%, transparent 8.5%),
			linear-gradient(145deg, #312d28, #0d0d0c);
		border: 4px solid white;
		border-radius: 28% 45% 38% 45%;
		box-shadow: 0 8px 25px rgba(20, 16, 10, 0.22);
		letter-spacing: 0;
		vertical-align: 0.08em;
		transform: rotate(-3deg);
	}

	.avatar > span {
		font-size: 0.22em;
	}

	.hero-muted {
		color: #aaa9a4;
	}

	.accent {
		color: #f06819;
	}

	.hero-action-row {
		display: flex;
		align-items: center;
		gap: 34px;
		margin-top: 34px;
	}

	.hero-actions {
		display: flex;
		gap: 10px;
		flex: none;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		min-height: 43px;
		padding: 0 17px;
		border-radius: 999px;
		font-size: 12px;
		font-weight: 700;
		text-decoration: none;
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			background 180ms ease;
	}

	.button:hover {
		transform: translateY(-2px);
	}

	.button :global(svg),
	.text-link :global(svg),
	.external :global(svg),
	.project-arrow :global(svg) {
		width: 14px;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 1.5;
	}

	.button-dark {
		color: white;
		background: #151513;
		box-shadow: 0 7px 18px rgba(15, 15, 14, 0.14);
	}

	.button-dark:hover {
		background: #f06819;
		box-shadow: 0 9px 24px rgba(240, 104, 25, 0.25);
	}

	.button-light {
		background: rgba(255, 255, 255, 0.72);
		border: 1px solid white;
	}

	.hero-action-row > p {
		max-width: 355px;
		margin: 0;
		color: #65645f;
		font-size: 13px;
		line-height: 1.55;
	}

	.bento {
		display: grid;
		grid-template-columns: 1.05fr 1.15fr 0.9fr;
		gap: 12px;
	}

	.card {
		position: relative;
		overflow: hidden;
		min-width: 0;
		padding: 18px;
		background: rgba(255, 255, 255, 0.7);
		border: 1px solid rgba(255, 255, 255, 0.96);
		border-radius: 20px;
		box-shadow:
			0 18px 45px rgba(36, 32, 24, 0.055),
			inset 0 0 0 1px rgba(20, 20, 18, 0.025);
		backdrop-filter: blur(16px);
	}

	a.card {
		text-decoration: none;
		transition:
			transform 220ms ease,
			box-shadow 220ms ease;
	}

	a.card:hover {
		z-index: 2;
		transform: translateY(-4px);
		box-shadow:
			0 24px 55px rgba(36, 32, 24, 0.1),
			inset 0 0 0 1px rgba(20, 20, 18, 0.03);
	}

	.card-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.external {
		display: grid;
		width: 25px;
		height: 25px;
		place-items: center;
		background: rgba(255, 255, 255, 0.65);
		border: 1px solid rgba(0, 0, 0, 0.05);
		border-radius: 50%;
	}

	.timeline-card {
		grid-row: span 2;
	}

	.timeline {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 23px;
		margin-top: 29px;
	}

	.timeline::before {
		position: absolute;
		top: 6px;
		bottom: 9px;
		left: 4px;
		width: 1px;
		background: #d2d1cb;
		content: "";
	}

	.timeline-item {
		position: relative;
		display: grid;
		grid-template-columns: 10px 1fr;
		gap: 13px;
		align-items: start;
	}

	.timeline-dot {
		z-index: 1;
		width: 9px;
		height: 9px;
		margin-top: 4px;
		background: #deddd8;
		border: 2px solid white;
		border-radius: 50%;
		box-shadow: 0 0 0 1px #c8c7c1;
	}

	.timeline-dot.active {
		background: #f06819;
		box-shadow: 0 0 0 1px #f06819;
	}

	.timeline-item strong,
	.timeline-item small {
		display: block;
	}

	.timeline-item strong {
		font-size: 12px;
		line-height: 1.4;
	}

	.timeline-item small {
		margin-top: 3px;
		color: #8a8983;
		font-size: 10px;
	}

	.deployer-card {
		min-height: 220px;
		padding-bottom: 14px;
		background:
			linear-gradient(145deg, rgba(255, 255, 255, 0.76), rgba(255, 239, 225, 0.74)),
			white;
	}

	.terminal {
		width: 94%;
		height: 119px;
		margin: 15px auto 0;
		overflow: hidden;
		background: #171815;
		border: 5px solid #eee9e1;
		border-radius: 13px 13px 7px 7px;
		box-shadow:
			0 16px 26px rgba(44, 32, 21, 0.19),
			0 0 0 1px #dad5ce;
		transform: perspective(500px) rotateX(1deg) rotateZ(-1.5deg);
	}

	.terminal-bar {
		display: flex;
		gap: 4px;
		padding: 7px;
		background: #f8f5f0;
	}

	.terminal-bar span {
		width: 5px;
		height: 5px;
		background: #d2cec8;
		border-radius: 50%;
	}

	.terminal-body {
		display: grid;
		grid-template-columns: 42px 1fr;
		height: calc(100% - 19px);
		color: white;
	}

	.terminal-sidebar {
		display: flex;
		flex-direction: column;
		gap: 8px;
		padding: 9px 7px;
		background: #20211e;
	}

	.terminal-sidebar b {
		font-size: 5px;
	}

	.terminal-sidebar i {
		width: 24px;
		height: 2px;
